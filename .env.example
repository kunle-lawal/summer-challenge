# Roster as JSON array
VITE_PEOPLE=[{"id":"kunle","name":"Kunle"},{"id":"ella","name":"Ella"},{"id":"scar","name":"Scar"},{"id":"marcus","name":"Marcus"},{"id":"will","name":"Will"}]

